# ====================================================================
# Crypto Fraud Tracker - Exemplo de configuracao
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA versione o .env real (ele esta no .gitignore).
# ====================================================================

# --- PostgreSQL ---
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=COLOQUE_UMA_SENHA_FORTE_AQUI
POSTGRES_DB=crypto_tracker
POSTGRES_URL=postgresql://crypto_user:COLOQUE_UMA_SENHA_FORTE_AQUI@postgres:5432/crypto_tracker

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=COLOQUE_UMA_SENHA_FORTE_AQUI
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/COLOQUE_UMA_SENHA_FORTE_AQUI

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Provider de inteligencia: 'mock' ou 'blockstream' ---
INTEL_PROVIDER=blockstream

# --- JWT ---
# Gere um secret forte com:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=GERE_UM_SECRET_FORTE_E_COLOQUE_AQUI
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- CORS e ambiente ---
# Origens permitidas (separadas por virgula). Em producao, use seu dominio.
ALLOWED_ORIGINS=http://localhost:3000
# Ambiente: 'dev' (Swagger ligado) ou 'prod' (Swagger escondido)
ENV=dev

# Optional: external wallet intelligence feed.
# Use the bundled example for local testing or replace it with OFAC/MISP/abuse-provider exports.
ADDRESS_INTEL_FILE=/app/data/address_intelligence.example.json
